# Copy this file to .env and fill in your values
# If OPENAI_API_KEY is not set, the system runs in mock-LLM mode automatically.

# OpenAI Configuration
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Force mock LLM regardless of API key (useful for testing)
# USE_MOCK_LLM=true

# Database path (SQLite)
DATABASE_URL=sqlite:///./data/underwriting.db

# Vector store path (directory for persisted TF-IDF index)
VECTOR_STORE_PATH=./data/vector_store
