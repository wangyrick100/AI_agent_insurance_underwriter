# ──────────────────────────────────────────────
# Underwriting Decision Support Suite – env vars
# Copy to .env and fill in real values
# ──────────────────────────────────────────────

# ── Azure OpenAI ─────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<key>
AZURE_OPENAI_API_VERSION=2024-06-01
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# ── Azure AI Search ──────────────────────────
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
AZURE_SEARCH_API_KEY=<key>
AZURE_SEARCH_INDEX_NAME=underwriting-docs

# ── Azure Key Vault ──────────────────────────
AZURE_KEYVAULT_URL=https://<your-vault>.vault.azure.net/

# ── Azure Storage (doc uploads) ──────────────
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_STORAGE_CONTAINER=underwriting-docs

# ── Database ─────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./underwriting.db

# ── App ──────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# ── Web Research Allowlist ───────────────────
WEB_ALLOWLIST_DOMAINS=nih.gov,cdc.gov,who.int,mayoclinic.org,uptodate.com,cms.gov,naic.org

# ── APIM ─────────────────────────────────────
APIM_GATEWAY_URL=https://<your-apim>.azure-api.net
APIM_SUBSCRIPTION_KEY=<key>
